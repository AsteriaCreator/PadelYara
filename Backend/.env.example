# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# Atlas connection string. Required — backend won't load venues or analytics without it.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
# Required for the newsletter double opt-in confirmation email.
BREVO_API_KEY=

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Optional — errors are logged to stdout without this.
SENTRY_DSN=

# ── Admin dashboard ───────────────────────────────────────────────────────────
# Protects /api/analytics endpoints. Set to any long random string.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=

# ── Frontend URL (CORS + confirmation emails) ─────────────────────────────────
# Default: https://www.padelyara.at
FRONTEND_URL=http://localhost:5173

# ── Google Search (opening hours refresh) ────────────────────────────────────
# Full JSON of a Google service account with Search Console access.
# Only needed if you want the weekly Eversports opening hours refresh to work.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Gemini (opening hours AI + Yara verdict page) ─────────────────────────────
GEMINI_API_KEY=
# Optional — overrides the default model
# YARA_URTEIL_MODEL=gemini-3.5-flash

# ── Groq (Yara verdict, alternative model) ────────────────────────────────────
GROQ_API_KEY=

# ── Eversports proxies (optional — only needed outside Railway) ───────────────
# Leave empty for local dev. Railway injects these automatically in production.
# EVERSPORTS_SLOT_PROXY=
# EVERSPORTS_CALENDAR_PROXY=
# EVERSPORTS_PROXY_URL=

# ── Railway (injected automatically — do not set manually) ────────────────────
# RAILWAY_ENVIRONMENT=production
# RAILWAY_STATIC_URL=
# PORT=8000
