# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend. Used to restrict CORS to known origins.
# Production: https://neo-padel-checker.vercel.app
FRONTEND_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas connection string. Required for analytics tracking.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
# Leave empty to disable analytics silently.
MONGODB_URI=

# ── Railway ───────────────────────────────────────────────────────────────────
# Set automatically by Railway at runtime. Controls whether Eversports scraping runs.
# Do NOT set this locally — omitting it disables the Cloudflare bypass scraper in dev.
# RAILWAY_ENVIRONMENT=production

# ── Server ────────────────────────────────────────────────────────────────────
# Injected by Railway at runtime. Defaults to 8000 locally.
PORT=8000
