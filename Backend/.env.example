# Copy this file to .env and fill in your values.
# Never commit .env to git.

# URL of the frontend (used for CORS). In development, Vite runs on 5173.
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/padel_checker?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/padel_checker?retryWrites=true&w=majority
